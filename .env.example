# ===== Browser-exposed keys (restrict by HTTP referrer in Google Cloud Console) =====
# Google Places API (New) — used by the address autocomplete on the landing page.
# Enable "Places API (New)" in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# ===== Server-only keys (never prefix with NEXT_PUBLIC_) =====

# --- Aerial tiles ---
# Which provider /api/tiles proxies to: "mapbox" (free tier, default) or "nearmap" (paid).
TILE_PROVIDER=mapbox
# Required if TILE_PROVIDER=mapbox. Get one at https://account.mapbox.com/access-tokens/
# A default public token (pk.…) works; for production restrict by URL.
MAPBOX_ACCESS_TOKEN=
# Required if TILE_PROVIDER=nearmap.
NEARMAP_API_KEY=

# --- Roof segmentation ---
# Replicate — used by meta/sam-2 for roof segmentation. ~$0.007 per click.
REPLICATE_API_TOKEN=

# --- Lead storage (Supabase) ---
# Create a free project at https://supabase.com. Run supabase/schema.sql in the SQL editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Contractor notifications (Resend) ---
# Sign up at https://resend.com. For the free tier, the `from` must be
# onboarding@resend.dev until you verify your domain.
RESEND_API_KEY=
LEAD_NOTIFICATION_FROM=onboarding@resend.dev
CONTRACTOR_NOTIFICATION_EMAIL=
