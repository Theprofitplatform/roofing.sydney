# ---- Browser-exposed keys (restrict by HTTP referrer in Google Cloud Console) ----
# Used by the address autocomplete on the landing page.
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# ---- Server-only keys (never prefix with NEXT_PUBLIC_) ----

# Nearmap — aerial imagery tile API. Proxied via /api/nearmap so the key never reaches the browser.
NEARMAP_API_KEY=

# Replicate — used later for SAM 2 roof segmentation.
REPLICATE_API_TOKEN=

# Supabase — used later for lead storage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — used later for contractor email notifications.
RESEND_API_KEY=
CONTRACTOR_NOTIFICATION_EMAIL=
